# OpenAI — used by ChatGPT agent
OPENAI_API_KEY=sk-your-openai-key-here

# xAI — used by Grok agent
XAI_API_KEY=xai-your-xai-key-here

# Google Gemini — used by Gemini agent (and as fallback for ChatGPT/Grok)
GEMINI_API_KEY=your-gemini-key-here

# Optional: per-agent Gemini fallback keys
# CHATGPT_GEMINI_KEY=your-gemini-key-for-chatgpt-fallback
# GROK_GEMINI_KEY=your-gemini-key-for-grok-fallback

# ── Web Research (optional but recommended) ───────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LOG_FORMAT options: text (human-readable), json (structured for log aggregators)
LOG_FORMAT=text
